def nav_citas():
    win_citas = tk.Toplevel(ventana)
    win_citas.title("Consultar y Eliminar Citas")
    win_citas.geometry("650x450")
    win_citas.configure(bg="#F2F2F2")
    #win_citas.grab_set()  #Se comentó para que no actúe como ventana modal, en caso de querer que lo haga, ya está el comando listo
    
    tk.Label(win_citas, text="Citas Agendadas", bg="#F2F2F2", fg="#333333", font=("Segoe UI", 16, "bold")).pack(pady=15)
    
    frame_lista = tk.Frame(win_citas, bg="#FFFFFF")
    frame_lista.pack(fill="both", expand=True, padx=25, pady=5)
    
    listbox = tk.Listbox(frame_lista, font=("Segoe UI", 11), selectbackground="#A200FF", selectforeground="white")
    listbox.pack(side="left", fill="both", expand=True)
    
    scrollbar = tk.Scrollbar(frame_lista, orient="vertical", command=listbox.yview)
    scrollbar.pack(side="right", fill="y")
    listbox.config(yscrollcommand=scrollbar.set)
    
    def cargar_citas():
        listbox.delete(0, tk.END)
        try:
            with open("citas.txt", "r", encoding="utf-8") as file:
                for linea in file:
                    if linea.strip():
                        # Formato: folio|cliente|servicio|dia|hora
                        partes = linea.strip().split('|')
                        if len(partes) == 5:
                            folio, cliente, servicio, dia, hora = partes
                            listbox.insert(tk.END, f"{folio} - {cliente} - {servicio} - {dia} {hora}")
        except FileNotFoundError:
            pass

    cargar_citas()
    
    def eliminar_cita():
        seleccion = listbox.curselection()
        if not seleccion:
            return
        
        index = seleccion[0]
        texto_item = listbox.get(index)
        folio_a_eliminar = texto_item.split(" - ")[0]
        
        try:
            lineas_restantes = []
            with open("citas.txt", "r", encoding="utf-8") as file:
                for linea in file:
                    if not linea.startswith(folio_a_eliminar + "|"):
                        lineas_restantes.append(linea)
                    else:
                        # Restaurar disponibilidad en el calendario (memoria)
                        partes = linea.strip().split('|')
                        if len(partes) == 5:
                            _, _, _, dia, hora = partes
                            if dia in HORARIOS_POR_DIA and hora in HORARIOS_POR_DIA[dia]:
                                HORARIOS_POR_DIA[dia][hora] = True
            
            with open("citas.txt", "w", encoding="utf-8") as file:
                file.writelines(lineas_restantes)
            
            cargar_citas()
        except FileNotFoundError:
            pass

    btn_eliminar = tk.Button(win_citas, text="Eliminar Cita", bg="#EF5350", fg="white", font=("Segoe UI", 12, "bold"), relief="flat", command=eliminar_cita)
    btn_eliminar.pack(pady=15)

