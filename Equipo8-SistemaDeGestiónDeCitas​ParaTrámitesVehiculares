def agendar_cita():
    # Obtener los datos de las entradas
    nombre = entrada_nombre.get()
    contacto = entrada_contacto.get()
    servicio = tipo_servicio.get()
    obs = caja_observaciones.get("1.0", "end-1c")

    def mostrar_error(mensaje):
        lbl_error = tk.Label(contenido, text=mensaje, bg=color_content, fg="#D32F2F", font=("Segoe UI", 12, "bold"))
        lbl_error.place(x=35, y=580)
        ventana.after(6000, lbl_error.destroy)

    # Verificar qué documentos se marcaron
    documentos = ""
    if var_ine.get() == 1:
        documentos = documentos + "[INE] "
    if var_domicilio.get() == 1:
        documentos = documentos + "[Comprobante de Domicilio] "
    if var_tarjeta.get() == 1:
        documentos = documentos + "[Tarjeta de Circulacion] "
    if var_multa.get() == 1:
        documentos = documentos + "[Certificado No Multas] "

    # Validacion basica
    if not validar_no_vacio(nombre):
        mostrar_error("error: el campo Nombre es obligatorio.")
        print("ERROR: el campo Nombre es obligatorio.")
    elif not validar_no_vacio(contacto):
        mostrar_error("error: el campo Teléfono de contacto es obligatorio.")
        print("ERROR: el campo Teléfono de contacto es obligatorio.")
    elif not validar_no_vacio(servicio):
        mostrar_error("error: tienes que seleccionar un tipo de servicio para agendar la cita")
    elif documentos == "":
        mostrar_error("error: tienes que seleccionar al menos un documento a presentar para agendar la cita")
    elif not validar_texto(nombre):
        mostrar_error("error: El nombre solo debe contener letras.")
        print("ERROR: El nombre solo debe contener letras.")
        entrada_nombre.delete(0, "end")  # limpia el Entry
    elif not validar_entero(contacto):
        mostrar_error("error: El teléfono de contacto no debe contener letras ni puntos.")
        print("ERROR: El teléfono de contacto no debe contener letras ni puntos.")
        entrada_contacto.delete(0, "end")  # limpia el Entry
    else:
        # Imprimir datos
        print("\n--- NUEVO REGISTRO DE CITA EXITOSO ---")
        print("Nombre del solicitante: " + nombre)
        print("Telefono de contacto: " + contacto)
        print("Tipo de Servicio: " + servicio)
        print("Documentacion: " + documentos)
        print("Observaciones: " + obs)
        print("--------------------------------------\n")

        # Limpiar el formulario para un nuevo registro
        entrada_nombre.delete(0, "end")
        entrada_contacto.delete(0, "end")
        tipo_servicio.set("")
        var_ine.set(0)
        var_domicilio.set(0)
        var_tarjeta.set(0)
        var_multa.set(0)
        caja_observaciones.delete("1.0", "end")

        # Abrir el calendario para elegir fecha y horario
        abrir_calendario(nombre, servicio)


