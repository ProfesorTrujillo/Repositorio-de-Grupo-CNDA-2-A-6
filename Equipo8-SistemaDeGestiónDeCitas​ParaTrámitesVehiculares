# ==========================================
# Validaciones Generales
# ==========================================

def validar_no_vacio(texto: str) -> bool:
    """
    Valida que el texto no esté vacío ni contenga solo espacios.
    """
    return bool(texto and texto.strip())

def clean_text(texto: str) -> str:
    """
    Limpia el texto de espacios en blanco.
    """
    return texto.strip()

def validar_texto(texto: str) -> bool:
    """
    Valida que el texto contenga solo letras y espacios.
    """
    # Al eliminar los espacios, verifica que los demás caracteres sean letras
    return texto.replace(" ", "").isalpha()

def validar_entero(texto: str) -> bool:
    """
    Valida que el texto sea un número entero.
    """
    try:
        int (texto)
        return True
    except ValueError:
        return False

def validar_rango(valor: int | float, minimo, maximo) -> bool:
    """
    Valida que un número esté dentro de un rango.
    """
    return minimo <= valor <= maximo


