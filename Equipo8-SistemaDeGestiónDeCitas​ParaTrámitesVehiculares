# Horarios disponibles por día (True = libre, False = ocupado)
HORARIOS_POR_DIA = {
    "Lunes":     {"09:00": False, "10:00": True,  "11:00": False, "12:00": True,  "13:00": True,  "16:00": False, "17:00": True},
    "Martes":    {"09:00": True,  "10:00": False,  "11:00": True,  "12:00": False, "13:00": True,  "16:00": True,  "17:00": False},
    "Miércoles": {"09:00": False, "10:00": True,  "11:00": True,  "12:00": True,  "13:00": False, "16:00": True,  "17:00": True},
    "Jueves":    {"09:00": True,  "10:00": True,  "11:00": False, "12:00": True,  "13:00": False, "16:00": False, "17:00": True},
    "Viernes":   {"09:00": True,  "10:00": False,  "11:00": True,  "12:00": False, "13:00": True,  "16:00": True,  "17:00": False},
}

# Cargar citas previas desde archivo para sincronizar disponibilidad del calendario
try:
    with open("citas.txt", "r", encoding="utf-8") as _f:
        for _linea in _f:
            if _linea.strip():
                _partes = _linea.strip().split('|')
                if len(_partes) == 5:
                    _, _, _, _dia, _hora = _partes
                    if _dia in HORARIOS_POR_DIA and _hora in HORARIOS_POR_DIA[_dia]:
                        HORARIOS_POR_DIA[_dia][_hora] = False
except FileNotFoundError:
    pass


def generar_folio(folios_existentes=None):
    """
    Genera un número de folio único con prefijo CITA- usando RECURSIVIDAD.
    Verifica que el folio no exista previamente en el archivo.
    """
    if folios_existentes is None:
        folios_existentes = set()
        try:
            with open("citas.txt", "r", encoding="utf-8") as f:
                for linea in f:
                    if linea.strip():
                        partes = linea.strip().split('|')
                        if len(partes) > 0:
                            folios_existentes.add(partes[0])
        except FileNotFoundError:
            pass

    nuevo_folio = f"CITA-{random.randint(10000, 99999)}"

    # Caso Base: El folio no está repetido, se retorna.
    if nuevo_folio not in folios_existentes:
        return nuevo_folio
    
    # Paso Recursivo: Si el folio ya existe, la función se llama a sí misma.
    return generar_folio(folios_existentes)


def seleccionar_horario(dia, hora, estado, lbl_mensaje, nombre_cliente, servicio, ventana_cal):
    """Maneja la selección de un horario en el calendario."""

    if estado == "ocupado":
        lbl_mensaje.config(
            fg="#EF5350",
            text=(f"⚠  El horario {hora} del día {dia} NO tiene disponibilidad para agendar su cita. "
                  f"Por favor elija un espacio marcado en verde.")
        )
        return

    # ----- Horario LIBRE: registrar y mostrar confirmación -----
    folio = generar_folio()

    # Marcar el horario como ocupado en el diccionario compartido
    HORARIOS_POR_DIA[dia][hora] = False

    # Ventana modal de confirmación
    conf = tk.Toplevel(ventana_cal)
    conf.title("¡Cita Agendada!")
    conf.geometry("450x400")
    conf.configure(bg="#0D0D1A")
    conf.resizable(False, False)
    #conf.grab_set() #Se comentó para que no actúe como ventana modal, en caso de querer que lo haga, ya está el comando listo

    tk.Label(conf, text="✅  Cita Confirmada", bg="#0D0D1A", fg="#4CAF50",
             font=("Segoe UI", 16, "bold")).pack(pady=(28, 4))
    tk.Label(conf, text="Su cita ha sido registrada exitosamente.",
             bg="#0D0D1A", fg="#B0B0CC", font=("Segoe UI", 10)).pack()

    info_frame = tk.Frame(conf, bg="#16213E", padx=20, pady=14)
    info_frame.pack(fill="x", padx=30, pady=16)

    datos = [
        ("Cliente:",  nombre_cliente),
        ("Servicio:", servicio),
        ("Día:",      dia),
        ("Horario:",  hora),
        ("Folio:",    folio),
    ]
    for etiqueta, valor in datos:
        fila = tk.Frame(info_frame, bg="#16213E")
        fila.pack(fill="x", pady=2)
        tk.Label(fila, text=etiqueta, bg="#16213E", fg="#B0B0CC",
                 font=("Segoe UI", 10), width=10, anchor="e").pack(side="left")
        color_valor = "#FFD700" if etiqueta == "Folio:" else "#E0E0FF"
        tk.Label(fila, text=valor, bg="#16213E", fg=color_valor,
                 font=("Segoe UI", 10, "bold"), anchor="w").pack(side="left", padx=6)

    def cerrar_ventanas():
        conf.destroy()
        ventana_cal.destroy()

    tk.Button(
        conf, text="✔  Listo",
        bg="#A200FF", fg="white", font=("Segoe UI", 11, "bold"),
        relief="flat", padx=20, pady=6,
        command=cerrar_ventanas
    ).pack(pady=(0, 20))

    print(f"\n--- CITA AGENDADA EXITOSAMENTE ---")
    print(f"Cliente : {nombre_cliente}")
    print(f"Servicio: {servicio}")
    print(f"Día     : {dia}")
    print(f"Horario : {hora}")
    print(f"Folio   : {folio}")
    print("----------------------------------\n")

    # Guardar cita en archivo
    try:
        with open("citas.txt", "a", encoding="utf-8") as f:
            f.write(f"{folio}|{nombre_cliente}|{servicio}|{dia}|{hora}\n")
    except Exception as e:
        print(f"Error al guardar la cita en archivo: {e}")


def abrir_calendario(nombre_cliente, servicio):
    """Abre la ventana emergente del calendario de citas."""

    C_BG      = "#1A1A2E"
    C_HEADER  = "#16213E"
    C_TITLE   = "#E0E0FF"
    C_SUB     = "#B0B0CC"
    FONT_TITLE = ("Segoe UI", 15, "bold")
    FONT_DAY   = ("Segoe UI", 11, "bold")
    FONT_SLOT  = ("Segoe UI", 10)
    FONT_BTN   = ("Segoe UI", 10, "bold")

    ventana_cal = tk.Toplevel(ventana)
    ventana_cal.title("Seleccionar Fecha y Horario")
    ventana_cal.geometry("920x530")
    ventana_cal.configure(bg=C_BG)
    ventana_cal.resizable(False, False)
    #ventana_cal.grab_set()   #Se comentó para que no actúe como ventana modal, en caso de querer que lo haga, ya está el comando listo

    # ---- Encabezado ----
    hdr = tk.Frame(ventana_cal, bg=C_HEADER, height=65)
    hdr.pack(fill="x")
    tk.Label(
        hdr, text="📅  Calendario de Disponibilidad",
        bg=C_HEADER, fg=C_TITLE, font=FONT_TITLE
    ).place(x=20, y=12)
    tk.Label(
        hdr, text=f"Cliente: {nombre_cliente}  |  Servicio: {servicio}",
        bg=C_HEADER, fg=C_SUB, font=("Segoe UI", 10)
    ).place(x=22, y=40)

    # ---- Leyenda de colores ----
    ley = tk.Frame(ventana_cal, bg=C_BG)
    ley.pack(fill="x", padx=20, pady=(8, 0))
    tk.Label(ley, text="■", fg="#4CAF50", bg=C_BG, font=("Segoe UI", 13)).pack(side="left")
    tk.Label(ley, text=" Disponible   ", fg=C_SUB, bg=C_BG, font=("Segoe UI", 10)).pack(side="left")
    tk.Label(ley, text="■", fg="#EF5350", bg=C_BG, font=("Segoe UI", 13)).pack(side="left")
    tk.Label(ley, text=" Ocupado", fg=C_SUB, bg=C_BG, font=("Segoe UI", 10)).pack(side="left")

    # ---- Etiqueta de mensajes de estado ----
    lbl_mensaje = tk.Label(
        ventana_cal,
        text="Seleccione un horario disponible para agendar su cita.",
        bg=C_BG, fg=C_SUB, font=("Segoe UI", 10, "italic"),
        wraplength=880, justify="left"
    )
    lbl_mensaje.pack(anchor="w", padx=20, pady=(6, 2))

    # ---- Grid del calendario ----
    grid_frame = tk.Frame(ventana_cal, bg=C_BG)
    grid_frame.pack(fill="both", expand=True, padx=20, pady=8)

    dias = list(HORARIOS_POR_DIA.keys())
    horarios_globales = ["09:00", "10:00", "11:00", "12:00", "13:00", "16:00", "17:00"]

    # Encabezados de días (columna 0 reservada para etiquetas de hora)
    for col, dia in enumerate(dias):
        tk.Label(
            grid_frame, text=dia,
            bg=C_HEADER, fg=C_TITLE, font=FONT_DAY,
            width=13, relief="flat", pady=6
        ).grid(row=0, column=col + 1, padx=3, pady=2, sticky="ew")

    # Filas de horarios
    for row, hora in enumerate(horarios_globales):
        # Etiqueta de hora
        tk.Label(
            grid_frame, text=hora,
            bg=C_BG, fg=C_SUB, font=FONT_SLOT,
            width=6, anchor="e"
        ).grid(row=row + 1, column=0, padx=(0, 8), pady=4, sticky="e")

        for col, dia in enumerate(dias):
            disponible = HORARIOS_POR_DIA[dia].get(hora, False)

            if disponible:
                bg_color = "#1B4332"
                fg_color = "#4CAF50"
                txt      = f"● {hora}"
                estado   = "libre"
            else:
                bg_color = "#3D0000"
                fg_color = "#EF5350"
                txt      = f"✕ {hora}"
                estado   = "ocupado"

            btn = tk.Button(
                grid_frame,
                text=txt,
                bg=bg_color,
                fg=fg_color,
                font=FONT_BTN,
                relief="flat",
                width=12,
                cursor="hand2" if disponible else "arrow",
                command=lambda d=dia, h=hora, s=estado: seleccionar_horario(
                    d, h, s, lbl_mensaje, nombre_cliente, servicio, ventana_cal
                )
            )
            btn.grid(row=row + 1, column=col + 1, padx=3, pady=3)

            # Efecto hover solo en slots libres
            if disponible:
                btn.bind("<Enter>", lambda e, b=btn: b.config(bg="#2D6A4F"))
                btn.bind("<Leave>", lambda e, b=btn: b.config(bg="#1B4332"))

    # ---- Botón Listo ----
    tk.Button(
        ventana_cal, text="✔  Listo",
        bg="#333355", fg="white", font=("Segoe UI", 10, "bold"),
        relief="flat", padx=20, pady=6,
        command=ventana_cal.destroy
    ).pack(pady=(0, 12))


